# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase (admin — keep secret, never commit, never share)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Portal session encryption (generate a random 64-char hex string: openssl rand -hex 32)
PORTAL_COOKIE_SECRET=your_random_64_char_hex_secret

# Stripe (optional)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Resend (email)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@your-domain.pf

# App URL (used for magic links, Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default team for storefront quote requests (find your team UUID in Supabase)
NEXT_PUBLIC_DEFAULT_TEAM_ID=your_team_uuid

# Google AI (embeddings text-embedding-004, 768 dims — gratuit via ai.google.dev)
GOOGLE_AI_API_KEY=your_google_ai_api_key

# Upstash Redis (rate limiting — required in production)
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Supabase Edge Functions (PDF generation)
SUPABASE_FUNCTIONS_URL=https://your-project-ref.supabase.co/functions/v1

# Cron security (generate: openssl rand -hex 32)
CRON_SECRET=your_cron_secret_hex
